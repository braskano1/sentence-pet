{
  "name": "sentence-pet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "emulators": "firebase emulators:start --only auth,firestore",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run src/firebase/rules.test.ts\"",
    "set-admin": "node scripts/set-admin-claim.mjs",
    "seed:export": "vite-node scripts/export-seed.ts",
    "seed:push": "node scripts/seed-content.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.15.0",
    "framer-motion": "^12.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "firebase-admin": "^14.1.0",
    "firebase-tools": "^15.22.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
